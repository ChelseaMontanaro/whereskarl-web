# Where's Karl web — public environment variables
#
# Copy this file to `.env.local` for local development.
# Set the same variables in your Vercel project for preview/production.
# Never commit `.env.local` or real secrets.

# Shared Where's Karl backend base URL (no trailing slash).
# Local: point at your running WheresKarl-Backend instance.
# Preview: point at your staging API host.
# Production: point at the shared production API host.
NEXT_PUBLIC_API_URL=
